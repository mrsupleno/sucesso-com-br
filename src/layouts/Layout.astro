---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  pubDate?: Date;
  author?: string;
}

const {
  title,
  description = 'Sucesso Empresarial - Consultoria, Treinamentos e Automacao de Processos',
  image,
  article = false,
  pubDate,
  author = 'Sucesso Empresarial'
} = Astro.props;

const siteUrl = 'https://sucesso.com.br';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="generator" content={Astro.generator}>
  <title>{title} | Sucesso Empresarial</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  {article && pubDate && (
    <meta property="article:published_time" content={pubDate.toISOString()}>
  )}
  {article && (
    <meta property="article:author" content={author}>
  )}

  <meta property="og:type" content={article ? 'article' : 'website'}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={`${title} | Sucesso Empresarial`}>
  <meta property="og:description" content={description}>
  <meta property="og:site_name" content="Sucesso Empresarial">
  {image && <meta property="og:image" content={image}>}

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={`${title} | Sucesso Empresarial`}>
  <meta name="twitter:description" content={description}>
  {image && <meta name="twitter:image" content={image}>}

  {article && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "author": { "@type": "Organization", "name": author },
      "publisher": { "@type": "Organization", "name": "Sucesso Empresarial", "url": siteUrl },
      "datePublished": pubDate?.toISOString(),
      "url": canonicalUrl
    })} />
  )}

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; line-height: 1.6; color: #1a3a5c; background: #f8f9fa; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    header { background: linear-gradient(135deg, #1a3a5c 0%, #2c5282 100%); color: white; padding: 60px 20px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    .logo { font-size: 2.5rem; font-weight: 700; margin-bottom: 10px; letter-spacing: -0.5px; }
    .logo a { color: white; text-decoration: none; }
    .tagline { font-size: 1.2rem; opacity: 0.95; font-weight: 400; }
    .nav-links { display: flex; justify-content: center; gap: 30px; margin-top: 20px; }
    .nav-links a { color: white; text-decoration: none; font-weight: 500; opacity: 0.9; transition: opacity 0.2s; }
    .nav-links a:hover { opacity: 1; }
    main { padding: 60px 20px; }
    footer { background: #1a3a5c; color: white; padding: 40px 20px; text-align: center; }
    .footer-links { margin-bottom: 20px; }
    .footer-links a { color: #2ecc71; text-decoration: none; margin: 0 15px; font-weight: 500; }
    .footer-links a:hover { opacity: 0.8; }
    .footer-info { font-size: 0.9rem; opacity: 0.85; line-height: 1.8; }
    .footer-info a { color: #2ecc71; text-decoration: none; }
    @media (max-width: 768px) { .logo { font-size: 2rem; } .nav-links { flex-direction: column; gap: 15px; } }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <div class="logo"><a href="/">Sucesso Empresarial</a></div>
      <div class="tagline">Consultoria, Treinamentos e Automacao</div>
      <nav class="nav-links">
        <a href="/">Inicio</a>
        <a href="/blog/">Blog</a>
        <a href="/privacidade.html">Privacidade</a>
        <a href="/termos.html">Termos</a>
      </nav>
    </div>
  </header>
  <main class="container"><slot /></main>
  <footer>
    <div class="container">
      <div class="footer-links">
        <a href="/privacidade.html">Politica de Privacidade</a>
        <a href="/termos.html">Termos de Uso</a>
        <a href="/blog/">Blog</a>
      </div>
      <div class="footer-info">
        <p><strong>Sucesso Empresarial Ltda</strong></p>
        <p>CNPJ: 01.655.728/0001-14</p>
        <p>Contato: <a href="mailto:mauricio@sucesso.com.br">mauricio@sucesso.com.br</a></p>
        <p style="margin-top: 20px; font-size: 0.85rem;">2026 Sucesso Empresarial. Todos os direitos reservados.</p>
      </div>
    </div>
  </footer>
</body>
</html>
