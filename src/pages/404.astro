---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina Nao Encontrada" description="A pagina que voce procura nao foi encontrada.">
  <div style="text-align: center; padding: 80px 20px;">
    <h1 style="font-size: 6rem; color: #1a3a5c; margin-bottom: 20px;">404</h1>
    <h2 style="font-size: 1.8rem; color: #1a3a5c; margin-bottom: 20px;">Pagina Nao Encontrada</h2>
    <p style="color: #4a5568; font-size: 1.1rem; margin-bottom: 40px;">
      A pagina que voce procura nao existe ou foi movida.
    </p>
    <a href="/" style="display: inline-block; background: #2ecc71; color: white; padding: 15px 30px; border-radius: 8px; text-decoration: none; font-weight: 600;">
      Voltar para Inicio
    </a>
  </div>
</Layout>
